# Atlassian OAuth Credentials
# Register at: https://developer.atlassian.com/console/
# Copy this file to .env and fill in your values.

# Jira — Create app → Authorization → OAuth 2.0 (3LO)
# Callback URL: http://localhost:27391/callback
# Scopes: read:jira-work, read:jira-user
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# Bitbucket — Workspace Settings → OAuth consumers → Add consumer
# Callback URL: http://localhost:27391/callback
# Scopes: Pull requests (Read), Account (Read)
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=

# Linear — Create an OAuth app at https://linear.app/settings/api/applications/new
# Callback URL: http://localhost:27391/callback
# Scopes: read, write (refresh tokens are included automatically)
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# GitHub — Create an OAuth App at https://github.com/settings/developers
# Callback URL: http://localhost:27391/callback
# Scopes: repo
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
