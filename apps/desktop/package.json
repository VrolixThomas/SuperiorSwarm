	"description": "SuperiorSwarm Desktop Application",
	"main": "./out/main/index.js",
	"type": "module",
	"author": "superiorswarm",
	"license": "MIT",
	"private": true,
	"scripts": {
		"postinstall": "[ ! -d node_modules/node-pty ] || find node_modules/node-pty -name spawn-helper -exec chmod +x {} + && electron-rebuild -f -w better-sqlite3",
		"dev": "electron-vite dev",
		"build": "electron-vite build",
		"dist": "electron-vite build && electron-builder --mac",
		"pack": "electron-vite build && electron-builder --mac --dir",
		"preview": "electron-vite preview",
		"test": "bun test",
		"type-check": "tsc --noEmit",
		"db:generate": "drizzle-kit generate"
	},
