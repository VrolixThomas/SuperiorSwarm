{
	"extends": "@superiorswarm/typescript-config/react.json",
	"compilerOptions": {
		"baseUrl": ".",
		"plugins": [{ "name": "next" }],
		"paths": {
			"@/*": ["./src/*"]
		},
		"outDir": "dist",
		"allowJs": true,
		"noEmit": true,
		"incremental": true,
		"jsx": "preserve"
	},
	"include": [
		"next-env.d.ts",
		"next.config.ts",
		"src/**/*.ts",
		"src/**/*.tsx",
		".next/types/**/*.ts"
	],
	"exclude": ["node_modules", "dist", ".next", "out"]
}
